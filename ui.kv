#:kivy 2.3.0

<MainScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 20
        Button:
            text: 'Start Exam'
            font_size: 24
            on_press: root.goto_exam()

<ExamScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 20
        Label:
            id: question_label
            text: ''
            font_size: 20
            size_hint_y: 0.2
        BoxLayout:
            id: options_box
            orientation: 'vertical'
            size_hint_y: 0.6
        Button:
            text: 'Next'
            size_hint_y: 0.2
            on_press: root.next_question()
