<LoginScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Label:
            text: "GO EXAM"
            font_size: 32

        TextInput:
            id: user
            hint_text: "Username"

        TextInput:
            id: pwd
            hint_text: "Password"
            password: True

        Button:
            text: "LOGIN"
            on_press: root.login()


<DashboardScreen>:
    BoxLayout:
        orientation: "vertical"

        Label:
            text: "Dashboard"

        Button:
            text: "Start Exam"
            on_press: root.start_exam()


<ExamScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20

        Label:
            id: question
            text: ""

        Button:
            id: opt0
            on_press: root.select(0)

        Button:
            id: opt1
            on_press: root.select(1)

        Button:
            id: opt2
            on_press: root.select(2)

        Button:
            id: opt3
            on_press: root.select(3)
